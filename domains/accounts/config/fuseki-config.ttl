@prefix : <http://jena.apache.org/fuseki#> .
@prefix fuseki: <http://jena.apache.org/fuseki#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2: <http://jena.apache.org/2016/09/TDB2#> .

# Service definition for Accounts domain SPARQL endpoint
<#accounts_service> a :Service ;
    rdfs:label "Accounts Domain SPARQL Service" ;
    :name "accounts" ;
    :endpoint [
        rdfs:label "SPARQL Query Endpoint" ;
        :operation fuseki:query ;
        :name "sparql"
    ] ;
    :endpoint [
        rdfs:label "SPARQL Update Endpoint" ;
        :operation fuseki:update ;
        :name "update"
    ] ;
    :endpoint [
        rdfs:label "Graph Store Protocol (read)" ;
        :operation fuseki:gsp-r ;
        :name "get"
    ] ;
    :endpoint [
        rdfs:label "Graph Store Protocol (read/write)" ;
        :operation fuseki:gsp-rw ;
        :name "data"
    ] ;
    :dataset <#accounts_dataset> .

# Dataset definition
<#accounts_dataset> a tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki-base/databases/accounts" ;
    rdfs:label "Accounts Domain RDF Dataset" ;
    rdfs:comment "Customer and Account RDF triples in TDB2 format" .
