@prefix : <http://jena.apache.org/fuseki#> .
@prefix fuseki: <http://jena.apache.org/fuseki#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2: <http://jena.apache.org/2016/09/TDB2#> .

# Service definition for Transactions domain SPARQL endpoint
<#transactions_service> a :Service ;
    rdfs:label "Transactions Domain SPARQL Service" ;
    :name "transactions" ;
    :endpoint [
        rdfs:label "SPARQL Query Endpoint" ;
        :operation fuseki:query ;
        :name "sparql"
    ] ;
    :endpoint [
        rdfs:label "SPARQL Update Endpoint" ;
        :operation fuseki:update ;
        :name "update"
    ] ;
    :endpoint [
        rdfs:label "Graph Store Protocol (read)" ;
        :operation fuseki:gsp-r ;
        :name "get"
    ] ;
    :endpoint [
        rdfs:label "Graph Store Protocol (read/write)" ;
        :operation fuseki:gsp-rw ;
        :name "data"
    ] ;
    :dataset <#transactions_dataset> .

# Dataset definition
<#transactions_dataset> a tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki-base/databases/transactions" ;
    rdfs:label "Transactions Domain RDF Dataset" ;
    rdfs:comment "Transaction and payment RDF triples in TDB2 format" .
