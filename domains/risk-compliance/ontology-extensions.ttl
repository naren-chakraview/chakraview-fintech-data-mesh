@prefix fintech: <https://chakracommerce.com/ontology/fintech/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# RISK/COMPLIANCE DOMAIN: RiskProfile Entity Type
# ============================================================================

fintech:RiskProfile
  a rdfs:Class ;
  rdfs:label "Risk Profile" ;
  rdfs:comment "Risk assessment and compliance status for a customer at a point in time" ;
  rdfs:subClassOf fintech:DomainEntity ;
  fintech:owningDomain "risk_compliance" .

# ============================================================================
# RISK/COMPLIANCE DOMAIN: RiskProfile Properties (Risk/Compliance domain owns these)
# ============================================================================

fintech:riskProfileId
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "Risk Profile ID" ;
  rdfs:comment "Unique identifier for this risk assessment" ;
  fintech:owningDomain "risk_compliance" .

fintech:riskScore
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:decimal ;
  rdfs:label "Risk Score" ;
  rdfs:comment "Numeric risk score ranging from 0.0 (no risk) to 1.0 (maximum risk)" ;
  fintech:owningDomain "risk_compliance" .

fintech:riskLevel
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "Risk Level" ;
  rdfs:comment "Categorical risk level classification: LOW, MEDIUM, HIGH, CRITICAL" ;
  fintech:owningDomain "risk_compliance" .

fintech:complianceStatus
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "Compliance Status" ;
  rdfs:comment "Compliance status: COMPLIANT, UNDER_REVIEW, NON_COMPLIANT, SUSPENDED" ;
  fintech:owningDomain "risk_compliance" .

fintech:kycStatus
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "KYC Verification Status" ;
  rdfs:comment "Know Your Customer verification status: NOT_STARTED, IN_PROGRESS, VERIFIED, REJECTED, EXPIRED" ;
  fintech:owningDomain "risk_compliance" .

fintech:fraudFlagsCount
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:integer ;
  rdfs:label "Fraud Flags Count" ;
  rdfs:comment "Total number of fraud flags or incidents associated with this customer" ;
  fintech:owningDomain "risk_compliance" .

fintech:lastReviewDate
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Last Review Date" ;
  rdfs:comment "Timestamp of the most recent risk assessment review" ;
  fintech:owningDomain "risk_compliance" .

fintech:nextReviewDate
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Next Review Date" ;
  rdfs:comment "Scheduled timestamp for the next risk assessment review" ;
  fintech:owningDomain "risk_compliance" .

fintech:reviewNotes
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "Review Notes" ;
  rdfs:comment "Human-written notes on the risk assessment findings and rationale (optional)" ;
  fintech:owningDomain "risk_compliance" .

# ============================================================================
# RISK/COMPLIANCE DOMAIN: Cross-Domain Linking Properties
# ============================================================================

fintech:forCustomer
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range fintech:Customer ;
  rdfs:label "For Customer" ;
  rdfs:comment "IRI reference to Customer entity from Accounts domain" ;
  fintech:owningDomain "risk_compliance" .

# ============================================================================
# RISK/COMPLIANCE DOMAIN: Metadata Properties (Standard across all domains)
# ============================================================================

fintech:sourceSystem
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "Source System" ;
  rdfs:comment "Identifier of the system from which this data originated (e.g., 'risk_compliance')" ;
  fintech:owningDomain "risk_compliance" .

fintech:sourceIngestionTime
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Source Ingestion Time" ;
  rdfs:comment "Timestamp when this data was ingested from the source system" ;
  fintech:owningDomain "risk_compliance" .
