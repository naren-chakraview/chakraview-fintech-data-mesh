@prefix : <http://jena.apache.org/fuseki#> .
@prefix fuseki: <http://jena.apache.org/fuseki#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2: <http://jena.apache.org/2016/09/TDB2#> .

# Service definition for Risk/Compliance domain SPARQL endpoint
<#risk_compliance_service> a :Service ;
    rdfs:label "Risk/Compliance Domain SPARQL Service" ;
    :name "risk_compliance" ;
    :endpoint [
        rdfs:label "SPARQL Query Endpoint" ;
        :operation fuseki:query ;
        :name "sparql"
    ] ;
    :endpoint [
        rdfs:label "SPARQL Update Endpoint" ;
        :operation fuseki:update ;
        :name "update"
    ] ;
    :endpoint [
        rdfs:label "Graph Store Protocol (read)" ;
        :operation fuseki:gsp-r ;
        :name "get"
    ] ;
    :endpoint [
        rdfs:label "Graph Store Protocol (read/write)" ;
        :operation fuseki:gsp-rw ;
        :name "data"
    ] ;
    :dataset <#risk_compliance_dataset> .

# Dataset definition
<#risk_compliance_dataset> a tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki-base/databases/risk_compliance" ;
    rdfs:label "Risk/Compliance Domain RDF Dataset" ;
    rdfs:comment "Risk assessments and compliance metrics RDF triples in TDB2 format" .
