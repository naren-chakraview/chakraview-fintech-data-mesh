@prefix fintech: <https://chakracommerce.com/ontology/fintech/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# ============================================================================
# Shared Fintech Ontology
# ============================================================================
# This is the "single source of truth" for the shared RDF schema across all
# fintech domains in the data mesh. It defines the core entity types and
# properties that are referenced and specialized by each domain.
#
# Design Principles:
# 1. Core entity definitions (Customer, Account, Transaction, Counterparty, RiskProfile)
# 2. Shared properties used across domains
# 3. Each domain specializes via domain-specific properties (see ontology-extensions.ttl)
# 4. Ownership is tracked via fintech:owningDomain property
#
# Ownership Model:
# - Accounts domain owns: Customer, Account
# - Transactions domain owns: Transaction, Counterparty
# - Risk/Compliance domain owns: RiskProfile, KYC records
#
# Cross-Domain References:
# - Transactions domain references Accounts domain Customer IRIs
# - Risk domain references both Accounts (Customer) and Transactions (Transaction)
# ============================================================================

# ============================================================================
# CORE ENTITY TYPES (Shared Definitions)
# ============================================================================

fintech:Customer
  a rdfs:Class ;
  rdfs:label "Customer" ;
  rdfs:comment "A financial customer or entity that holds accounts and initiates transactions. Owned by Accounts domain. Customer IRIs are minted deterministically from email + KYC ID to enable entity deduplication across domains." ;
  fintech:owningDomain "accounts" ;
  owl:sameAs [ owl:onProperty fintech:email ; owl:hasValue "customer_identifier" ] .

fintech:Account
  a rdfs:Class ;
  rdfs:label "Account" ;
  rdfs:comment "A financial account held by a Customer. Includes deposit accounts, investment accounts, and credit facilities. Owned by Accounts domain." ;
  fintech:owningDomain "accounts" ;
  rdfs:subClassOf [ a owl:Restriction ;
                    owl:onProperty fintech:accountCustomer ;
                    owl:allValuesFrom fintech:Customer ] .

fintech:Transaction
  a rdfs:Class ;
  rdfs:label "Transaction" ;
  rdfs:comment "A payment or financial transaction between a Customer (debtor) and a Counterparty (creditor). Includes settlement status and clearing information. Owned by Transactions domain." ;
  fintech:owningDomain "transactions" ;
  rdfs:subClassOf [ a owl:Restriction ;
                    owl:onProperty fintech:transactionDebtor ;
                    owl:allValuesFrom fintech:Customer ] ;
  rdfs:subClassOf [ a owl:Restriction ;
                    owl:onProperty fintech:transactionCreditor ;
                    owl:allValuesFrom fintech:Counterparty ] .

fintech:Counterparty
  a rdfs:Class ;
  rdfs:label "Counterparty" ;
  rdfs:comment "A payment processor, merchant, bank, or other external entity that participates in transactions. Examples: Stripe, PayPal, Bank of America. Owned by Transactions domain." ;
  fintech:owningDomain "transactions" .

fintech:RiskProfile
  a rdfs:Class ;
  rdfs:label "Risk Profile" ;
  rdfs:comment "A risk assessment for a Customer including fraud score, KYC status, AML flags, and compliance status. Owned by Risk/Compliance domain." ;
  fintech:owningDomain "risk-compliance" ;
  rdfs:subClassOf [ a owl:Restriction ;
                    owl:onProperty fintech:riskCustomer ;
                    owl:allValuesFrom fintech:Customer ] .

# ============================================================================
# SHARED PROPERTIES (Used Across Domains)
# ============================================================================

fintech:owningDomain
  a rdf:Property ;
  rdfs:label "Owning Domain" ;
  rdfs:comment "Indicates which domain owns this entity type or property. Values: accounts, transactions, risk-compliance, market-data, counterparties, federation." ;
  rdfs:range xsd:string .

fintech:sourceSystem
  a rdf:Property ;
  rdfs:label "Source System" ;
  rdfs:comment "The originating system from which this data was loaded. Examples: payments-system-v2, customer-crm, risk-engine." ;
  rdfs:range xsd:string .

fintech:sourceIngestionTime
  a rdf:Property ;
  rdfs:label "Source Ingestion Time" ;
  rdfs:comment "When this record was loaded into the semantic layer (ingestion timestamp)." ;
  rdfs:range xsd:dateTime .

fintech:dataQualityScore
  a rdf:Property ;
  rdfs:label "Data Quality Score" ;
  rdfs:comment "Quality metric for this entity (0.0-1.0). Used for filtering low-quality data in queries." ;
  rdfs:range xsd:decimal .

# ============================================================================
# ACCOUNTS DOMAIN: Customer Entity Properties
# ============================================================================
# Owned by: Accounts domain
# Definition: Core customer identity and demographics

fintech:email
  a rdf:Property ;
  rdfs:domain fintech:Customer ;
  rdfs:range xsd:string ;
  rdfs:label "Email" ;
  rdfs:comment "Customer email address. Used for IRI minting (sha256(email|kyc_id))" ;
  fintech:owningDomain "accounts" .

fintech:kycId
  a rdf:Property ;
  rdfs:domain fintech:Customer ;
  rdfs:range xsd:string ;
  rdfs:label "KYC ID" ;
  rdfs:comment "Know-Your-Customer identifier from identity verification system. Used for IRI minting and regulatory compliance." ;
  fintech:owningDomain "accounts" .

fintech:name
  a rdf:Property ;
  rdfs:domain fintech:Customer ;
  rdfs:range xsd:string ;
  rdfs:label "Name" ;
  rdfs:comment "Customer full name or legal entity name" ;
  fintech:owningDomain "accounts" .

fintech:kycStatus
  a rdf:Property ;
  rdfs:domain fintech:Customer ;
  rdfs:range xsd:string ;
  rdfs:label "KYC Status" ;
  rdfs:comment "Customer KYC verification status (verified, pending, rejected, expired)" ;
  fintech:owningDomain "accounts" .

fintech:customerType
  a rdf:Property ;
  rdfs:domain fintech:Customer ;
  rdfs:range xsd:string ;
  rdfs:label "Customer Type" ;
  rdfs:comment "Classification of customer (individual, business, institutional, nonprofit)" ;
  fintech:owningDomain "accounts" .

# ============================================================================
# ACCOUNTS DOMAIN: Account Entity Properties
# ============================================================================
# Owned by: Accounts domain
# Definition: Account structure and balance tracking

fintech:accountId
  a rdf:Property ;
  rdfs:domain fintech:Account ;
  rdfs:range xsd:string ;
  rdfs:label "Account ID" ;
  rdfs:comment "Unique account identifier" ;
  fintech:owningDomain "accounts" .

fintech:accountCustomer
  a rdf:Property ;
  rdfs:domain fintech:Account ;
  rdfs:range fintech:Customer ;
  rdfs:label "Account Owner" ;
  rdfs:comment "Customer who owns this account" ;
  fintech:owningDomain "accounts" .

fintech:accountType
  a rdf:Property ;
  rdfs:domain fintech:Account ;
  rdfs:range xsd:string ;
  rdfs:label "Account Type" ;
  rdfs:comment "Type of account (deposit, investment, credit, savings, etc.)" ;
  fintech:owningDomain "accounts" .

fintech:accountStatus
  a rdf:Property ;
  rdfs:domain fintech:Account ;
  rdfs:range xsd:string ;
  rdfs:label "Account Status" ;
  rdfs:comment "Status of account (active, suspended, closed, dormant)" ;
  fintech:owningDomain "accounts" .

fintech:currentBalance
  a rdf:Property ;
  rdfs:domain fintech:Account ;
  rdfs:range xsd:decimal ;
  rdfs:label "Current Balance" ;
  rdfs:comment "Latest account balance in base currency" ;
  fintech:owningDomain "accounts" .

# ============================================================================
# TRANSACTIONS DOMAIN: Transaction Entity Properties
# ============================================================================
# Owned by: Transactions domain
# Definition: Payment transactions and settlement

fintech:transactionId
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range xsd:string ;
  rdfs:label "Transaction ID" ;
  rdfs:comment "Unique transaction identifier from source system" ;
  fintech:owningDomain "transactions" .

fintech:transactionAmount
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range xsd:decimal ;
  rdfs:label "Transaction Amount" ;
  rdfs:comment "Transaction amount in base currency (USD)" ;
  fintech:owningDomain "transactions" .

fintech:transactionStatus
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range xsd:string ;
  rdfs:label "Transaction Status" ;
  rdfs:comment "Current status of transaction (executed, pending, failed, cancelled)" ;
  fintech:owningDomain "transactions" .

fintech:transactionDate
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Transaction Date" ;
  rdfs:comment "When the transaction occurred" ;
  fintech:owningDomain "transactions" .

fintech:transactionDebtor
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range fintech:Customer ;
  rdfs:label "Debtor" ;
  rdfs:comment "Customer initiating the transaction (payer). Links to Customer IRI from Accounts domain." ;
  fintech:owningDomain "transactions" .

fintech:transactionCreditor
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range fintech:Counterparty ;
  rdfs:label "Creditor" ;
  rdfs:comment "Receiving counterparty (payment processor, merchant, bank)" ;
  fintech:owningDomain "transactions" .

fintech:settlementStatus
  a rdf:Property ;
  rdfs:domain fintech:Transaction ;
  rdfs:range xsd:string ;
  rdfs:label "Settlement Status" ;
  rdfs:comment "Clearing and settlement status (pending, cleared, failed, on-hold)" ;
  fintech:owningDomain "transactions" .

# ============================================================================
# TRANSACTIONS DOMAIN: Counterparty Entity Properties
# ============================================================================
# Owned by: Transactions domain
# Definition: External payment processors and merchants

fintech:counterpartyId
  a rdf:Property ;
  rdfs:domain fintech:Counterparty ;
  rdfs:range xsd:string ;
  rdfs:label "Counterparty ID" ;
  rdfs:comment "Unique counterparty identifier (e.g., stripe, paypal, bofa)" ;
  fintech:owningDomain "transactions" .

fintech:counterpartyName
  a rdf:Property ;
  rdfs:domain fintech:Counterparty ;
  rdfs:range xsd:string ;
  rdfs:label "Counterparty Name" ;
  rdfs:comment "Human-readable name (e.g., Stripe Inc., PayPal Holdings)" ;
  fintech:owningDomain "transactions" .

fintech:counterpartyType
  a rdf:Property ;
  rdfs:domain fintech:Counterparty ;
  rdfs:range xsd:string ;
  rdfs:label "Counterparty Type" ;
  rdfs:comment "Type of counterparty (processor, merchant, bank, exchange, etc.)" ;
  fintech:owningDomain "transactions" .

# ============================================================================
# RISK & COMPLIANCE DOMAIN: Risk Profile Properties
# ============================================================================
# Owned by: Risk/Compliance domain
# Definition: Risk assessments and compliance flags

fintech:riskCustomer
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range fintech:Customer ;
  rdfs:label "Risk Customer" ;
  rdfs:comment "Customer associated with this risk profile" ;
  fintech:owningDomain "risk-compliance" .

fintech:fraudScore
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:decimal ;
  rdfs:label "Fraud Score" ;
  rdfs:comment "Fraud risk score (0.0-1.0, where 1.0 is highest risk)" ;
  fintech:owningDomain "risk-compliance" .

fintech:amlFlag
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:boolean ;
  rdfs:label "AML Flag" ;
  rdfs:comment "Anti-Money Laundering flag (true if customer flagged for investigation)" ;
  fintech:owningDomain "risk-compliance" .

fintech:complianceStatus
  a rdf:Property ;
  rdfs:domain fintech:RiskProfile ;
  rdfs:range xsd:string ;
  rdfs:label "Compliance Status" ;
  rdfs:comment "Regulatory compliance status (compliant, at-risk, suspended, flagged)" ;
  fintech:owningDomain "risk-compliance" .

# ============================================================================
# Cross-Domain Linking and Federation Guidelines
# ============================================================================
#
# IRI Minting Rules (Deterministic, idempotent):
#
# 1. Customer IRIs (owned by Accounts domain):
#    Format: https://chakracommerce.com/customer#{hash}
#    Hash: SHA-256(normalize(email) | normalize(kyc_id))
#    Example: https://chakracommerce.com/customer#a1b2c3d4
#
# 2. Account IRIs (owned by Accounts domain):
#    Format: https://chakracommerce.com/account#{id}
#    Basis: Direct identity from account_id field
#
# 3. Transaction IRIs (owned by Transactions domain):
#    Format: https://chakracommerce.com/transaction#{id}
#    Basis: Direct identity from transaction_id field
#
# 4. Counterparty IRIs (owned by Transactions domain):
#    Format: https://chakracommerce.com/counterparty#{id}
#    Basis: Direct identity from counterparty_id field
#
# 5. RiskProfile IRIs (owned by Risk domain):
#    Format: https://chakracommerce.com/risk-profile#{id}
#    Basis: Customer IRI + timestamp
#
# Cross-Domain References:
# - Transactions.transactionDebtor → Customer IRI (from Accounts)
# - RiskProfile.riskCustomer → Customer IRI (from Accounts)
# - RiskProfile can also reference Transaction IRIs
#
# Federation Example:
# A transaction links to a customer (in Accounts domain).
# A risk profile links to the same customer and transaction.
# Queries can traverse across domains via shared IRIs.
#
# ============================================================================
